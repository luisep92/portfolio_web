---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
---

<BaseLayout>
  <Container class="py-24">
    <p class="text-lg leading-relaxed text-neutral-200">
      Engineer at KEO-Connectivity, contributing to the
      <a
        href="https://www.eebus.org/"
        class="text-neutral-100 underline-offset-4 hover:underline"
        rel="noopener"
        target="_blank"
        >EEBUS protocol</a
      >
      — the open standard for energy device interoperability. I focus on the C++ API and the testing layer that keeps it honest.
    </p>
    <p class="mt-6 text-lg leading-relaxed text-neutral-200">
      Outside of work I ship side projects in whatever stack fits the problem. AI-augmented development is part of how I work, on my own terms — the context-driven workflow I run today predates the shorthand for it.
    </p>
    <p class="mt-12 text-neutral-400">
      Selected work and ongoing experiments live in
      <a href="/projects" class="text-neutral-100 underline-offset-4 hover:underline">projects</a>.
    </p>
  </Container>
</BaseLayout>
