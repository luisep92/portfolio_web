---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import { isVisible, entryIdToParts } from '../../lib/content';
import { getLocaleFromUrl, localizedPath, t } from '../../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const heading = t(locale, 'nav.articles');

const all = await getCollection('articles', (entry) => {
  const { locale: entryLocale } = entryIdToParts(entry.id);
  return entryLocale === locale && isVisible(entry);
});

type ArticleEntry = CollectionEntry<'articles'>;
const byNewest = (a: ArticleEntry, b: ArticleEntry) =>
  b.data.publishedAt.getTime() - a.data.publishedAt.getTime();
const articles = all.sort(byNewest);

const dateLocale = locale === 'es' ? 'es-ES' : 'en-US';
const formatter = new Intl.DateTimeFormat(dateLocale, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

function detailHref(entry: ArticleEntry): string {
  const { slug } = entryIdToParts(entry.id);
  return localizedPath(`/articles/${slug}`, locale);
}
---

<BaseLayout title={`${heading} — ${t(locale, 'site.title')}`}>
  <Container class="py-24">
    <h1 class="text-4xl font-semibold tracking-tight">{heading}</h1>

    {articles.length > 0 ? (
      <ul class="mt-16 border-t border-slate-900">
        {articles.map((entry) => (
          <li>
            <a
              href={detailHref(entry)}
              class="group -mx-4 block rounded border-b border-slate-900 px-4 py-6 transition-colors hover:bg-slate-900/50"
            >
              <div class="flex items-baseline justify-between gap-4">
                <h2 class="text-xl font-medium text-slate-100">
                  {entry.data.title}
                  <span class="ml-1 inline-block opacity-0 transition-all duration-200 group-hover:translate-x-1 group-hover:opacity-100">
                    →
                  </span>
                </h2>
                <span class="shrink-0 text-sm text-slate-500">
                  {formatter.format(entry.data.publishedAt)}
                </span>
              </div>
              <p class="mt-2 leading-relaxed text-slate-400">{entry.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="mt-16 text-slate-400">{t(locale, 'articles.empty')}</p>
    )}
  </Container>
</BaseLayout>
