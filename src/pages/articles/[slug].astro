---
import { getEntryByLocale, getSlugsByLocaleUnion } from '../../lib/content';
import { otherLocale } from '../../i18n/utils';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import MissingTranslationNotice from '../../components/MissingTranslationNotice.astro';

const PAGE_LOCALE = 'en' as const;

export async function getStaticPaths() {
  const all = await getSlugsByLocaleUnion('articles');
  return [...all.keys()].map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const entry = await getEntryByLocale('articles', slug!, PAGE_LOCALE);
const fallback = entry
  ? null
  : await getEntryByLocale('articles', slug!, otherLocale(PAGE_LOCALE));
---

{
  entry ? (
    <ArticleLayout entry={entry} />
  ) : fallback ? (
    <BaseLayout>
      <MissingTranslationNotice
        availableEntry={fallback}
        availableLocale={otherLocale(PAGE_LOCALE)}
        collection="articles"
        slug={slug!}
        locale={PAGE_LOCALE}
      />
    </BaseLayout>
  ) : (
    <BaseLayout title="Not found — Luis Escolano">
      <Container class="py-24">
        <h1 class="text-3xl font-semibold tracking-tight">404</h1>
        <p class="mt-3 text-slate-400">This entry doesn't exist.</p>
      </Container>
    </BaseLayout>
  )
}
