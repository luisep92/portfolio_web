---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import { getLocaleFromUrl, t } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const heading = t(locale, 'nav.now');
const lastUpdated = '2026-05-10';
---

<BaseLayout title={`${heading} — ${t(locale, 'site.title')}`}>
  <Container class="py-24">
    <h1 class="text-3xl font-semibold tracking-tight">{heading}</h1>
    <div class="mt-8 space-y-5 text-slate-200 leading-relaxed">
      <p>
        Day job: working on the EEBUS C++ API and the testing layer at KEO-Connectivity, in the EEBUS Initiative.
      </p>
      <p>
        Side, active: shaping an Aline boss fight (Beat Saber / Vivify) into a Vivify mapping harness with AI assistance — Unity template, MCP tools, Claude Code skills. The map is the validation case; the harness is what I want to ship. Two short clips up at <a href="/projects/aline-boss-fight" class="text-slate-100 underline-offset-4 hover:underline">/projects/aline-boss-fight</a>.
      </p>
      <p>
        Also: this site, slowly clearing a backlog of writeups for side projects that have lived in private repos too long.
      </p>
    </div>
    <p class="mt-12 text-xs uppercase tracking-wide text-slate-500">
      {t(locale, 'now.last_updated')}: {lastUpdated}
    </p>
  </Container>
</BaseLayout>
