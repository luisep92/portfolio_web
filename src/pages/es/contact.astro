---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import { getLocaleFromUrl, t } from '../../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const heading = t(locale, 'nav.contact');

const links = [
  { label: 'Email', display: 'luis@escolano.es', href: 'mailto:luis@escolano.es' },
  { label: 'GitHub', display: 'luisep92', href: 'https://github.com/luisep92' },
  {
    label: 'LinkedIn',
    display: 'luis-escolano-piquer',
    href: 'https://www.linkedin.com/in/luis-escolano-piquer-24405b385/',
  },
];
---

<BaseLayout title={`${heading} — ${t(locale, 'site.title')}`}>
  <Container class="py-24">
    <h1 class="text-3xl font-semibold tracking-tight">{heading}</h1>
    <p class="mt-6 text-slate-300">Mejor por email.</p>
    <ul class="mt-8 space-y-3 text-slate-200">
      {
        links.map((link) => (
          <li>
            <span class="text-slate-500">{link.label} —&nbsp;</span>
            <a
              href={link.href}
              class="text-slate-100 underline-offset-4 hover:underline"
              rel={link.href.startsWith('http') ? 'noopener' : undefined}
              target={link.href.startsWith('http') ? '_blank' : undefined}
            >
              {link.display}
            </a>
          </li>
        ))
      }
    </ul>
  </Container>
</BaseLayout>
