---
import '../../styles/global.css';
import LocaleToggle from '../../components/layout/LocaleToggle.astro';
import { getLocaleFromUrl, t } from '../../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{t(locale, 'site.title')}</title>
  </head>
  <body class="bg-neutral-950 text-neutral-100 antialiased">
    <header class="mx-auto flex max-w-2xl items-center justify-between px-8 py-8">
      <span class="text-sm text-neutral-500">{t(locale, 'site.title')}</span>
      <LocaleToggle />
    </header>
    <main class="mx-auto max-w-2xl px-8 py-16">
      <h1 class="text-3xl font-semibold tracking-tight">{t(locale, 'site.title')}</h1>
      <p class="mt-3 text-neutral-400">{t(locale, 'home.placeholder.body')}</p>
    </main>
  </body>
</html>
