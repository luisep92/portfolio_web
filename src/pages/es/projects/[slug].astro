---
import { getEntryByLocale, getSlugsByLocaleUnion } from '../../../lib/content';
import { otherLocale } from '../../../i18n/utils';
import ProjectLayout from '../../../layouts/ProjectLayout.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/ui/Container.astro';
import MissingTranslationNotice from '../../../components/MissingTranslationNotice.astro';

const PAGE_LOCALE = 'es' as const;

export async function getStaticPaths() {
  const featured = await getSlugsByLocaleUnion(
    'projects',
    (entry) => entry.data.tier === 'featured',
  );
  return [...featured.keys()].map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const entry = await getEntryByLocale('projects', slug!, PAGE_LOCALE);
const fallback = entry
  ? null
  : await getEntryByLocale('projects', slug!, otherLocale(PAGE_LOCALE));
---

{
  entry ? (
    <ProjectLayout entry={entry} />
  ) : fallback ? (
    <BaseLayout>
      <MissingTranslationNotice
        availableEntry={fallback}
        availableLocale={otherLocale(PAGE_LOCALE)}
        collection="projects"
        slug={slug!}
        locale={PAGE_LOCALE}
      />
    </BaseLayout>
  ) : (
    <BaseLayout title="No encontrado — Luis Escolano">
      <Container class="py-24">
        <h1 class="text-3xl font-semibold tracking-tight">404</h1>
        <p class="mt-3 text-neutral-400">Esta entrada no existe.</p>
      </Container>
    </BaseLayout>
  )
}
