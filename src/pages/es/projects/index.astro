---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/ui/Container.astro';
import { isVisible, entryIdToParts } from '../../../lib/content';
import { getLocaleFromUrl, localizedPath, t } from '../../../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const heading = t(locale, 'nav.projects');

const all = await getCollection('projects', (entry) => {
  const { locale: entryLocale } = entryIdToParts(entry.id);
  return entryLocale === locale && isVisible(entry);
});

type ProjectEntry = CollectionEntry<'projects'>;
const byOrder = (a: ProjectEntry, b: ProjectEntry) => a.data.order - b.data.order;
const featured = all.filter((e) => e.data.tier === 'featured').sort(byOrder);
const other = all.filter((e) => e.data.tier === 'other').sort(byOrder);

function detailHref(entry: ProjectEntry): string {
  const { slug } = entryIdToParts(entry.id);
  return localizedPath(`/projects/${slug}`, locale);
}

// Group "other" entries by year, descending. Within a year, the existing
// `order` field acts as the secondary sort (already applied above).
// Entries without `year` fall into bucket 0 and render at the bottom.
function groupByYear(entries: ProjectEntry[]): Array<[number, ProjectEntry[]]> {
  const map = new Map<number, ProjectEntry[]>();
  for (const entry of entries) {
    const year = entry.data.year ?? 0;
    if (!map.has(year)) map.set(year, []);
    map.get(year)!.push(entry);
  }
  return [...map.entries()].sort(([a], [b]) => b - a);
}

const otherByYear = groupByYear(other);
---

<BaseLayout title={`${heading} — ${t(locale, 'site.title')}`}>
  <Container class="py-24">
    <h1 class="text-4xl font-semibold tracking-tight">{heading}</h1>

    <section class="mt-16">
      <h2 class="text-xs font-medium uppercase tracking-wide text-slate-500">
        {t(locale, 'projects.featured_heading')}
      </h2>

      {featured.length > 0 ? (
        <ul class="mt-6 border-t border-slate-900">
          {featured.map((entry) => (
            <li>
              <a
                href={detailHref(entry)}
                class="group -mx-4 block rounded border-b border-slate-900 px-4 py-6 transition-colors hover:bg-slate-900/50"
              >
                <div class="flex items-baseline justify-between gap-4">
                  <h3 class="text-xl font-medium text-slate-100">
                    {entry.data.title}
                    <span class="ml-1 inline-block opacity-0 transition-all duration-200 group-hover:translate-x-1 group-hover:opacity-100">
                      →
                    </span>
                  </h3>
                  {entry.data.year && (
                    <span class="shrink-0 text-sm text-slate-500">{entry.data.year}</span>
                  )}
                </div>
                <p class="mt-2 leading-relaxed text-slate-400">{entry.data.summary}</p>
                {entry.data.role && (
                  <p class="mt-3 text-xs uppercase tracking-wide text-slate-500">
                    {entry.data.role}
                  </p>
                )}
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="mt-6 text-slate-400">{t(locale, 'projects.empty')}</p>
      )}
    </section>

    {other.length > 0 && (
      <section class="mt-20">
        <h2 class="text-xs font-medium uppercase tracking-wide text-slate-500">
          {t(locale, 'projects.other_heading')}
        </h2>

        <div class="mt-10 space-y-12">
          {otherByYear.map(([year, entries]) => (
            <div>
              <h3 class="mb-5 text-lg font-semibold tracking-tight text-slate-200">
                {year > 0 ? year : '—'}
              </h3>
              <ol class="project-timeline">
                {entries.map((entry) => {
                  const repo = entry.data.links?.repo;
                  const article = entry.data.links?.article;
                  const demo = entry.data.links?.demo;
                  const externalHref = repo ?? article ?? demo;
                  const role = entry.data.role;
                  const tags = entry.data.tags;
                  const highlight = entry.data.highlight;
                  return (
                    <li class="project-timeline-item">
                      {externalHref ? (
                        <a
                          href={externalHref}
                          class="group block rounded-md px-3 py-2 transition-colors hover:bg-slate-900/50"
                          rel="noopener"
                          target="_blank"
                        >
                          <div class="flex items-baseline justify-between gap-4">
                            <h4 class="text-base font-medium text-slate-200 group-hover:text-slate-100">
                              {entry.data.title}
                              <span class="ml-1 inline-block text-slate-500 transition-all duration-200 group-hover:translate-x-0.5 group-hover:text-slate-200">↗</span>
                            </h4>
                            {role && <span class="shrink-0 text-xs text-slate-500">{role}</span>}
                          </div>
                          {(highlight || (tags && tags.length > 0)) && (
                            <ul class="mt-2 flex flex-wrap gap-1.5">
                              {highlight && (
                                <li class="rounded-full bg-slate-200 px-2 py-0.5 text-[0.6875rem] font-medium text-slate-950">
                                  {highlight}
                                </li>
                              )}
                              {tags && tags.map((tag) => (
                                <li class="rounded-full border border-slate-700 px-2 py-0.5 text-[0.6875rem] text-slate-400">
                                  {tag}
                                </li>
                              ))}
                            </ul>
                          )}
                          <p class="mt-2 text-sm leading-relaxed text-slate-400">
                            {entry.data.summary}
                          </p>
                        </a>
                      ) : (
                        <div class="px-3 py-2">
                          <div class="flex items-baseline justify-between gap-4">
                            <h4 class="text-base font-medium text-slate-200">{entry.data.title}</h4>
                            {role && <span class="shrink-0 text-xs text-slate-500">{role}</span>}
                          </div>
                          {(highlight || (tags && tags.length > 0)) && (
                            <ul class="mt-2 flex flex-wrap gap-1.5">
                              {highlight && (
                                <li class="rounded-full bg-slate-200 px-2 py-0.5 text-[0.6875rem] font-medium text-slate-950">
                                  {highlight}
                                </li>
                              )}
                              {tags && tags.map((tag) => (
                                <li class="rounded-full border border-slate-700 px-2 py-0.5 text-[0.6875rem] text-slate-400">
                                  {tag}
                                </li>
                              ))}
                            </ul>
                          )}
                          <p class="mt-2 text-sm leading-relaxed text-slate-400">
                            {entry.data.summary}
                          </p>
                        </div>
                      )}
                    </li>
                  );
                })}
              </ol>
            </div>
          ))}
        </div>
      </section>
    )}
  </Container>
</BaseLayout>

<style>
  .project-timeline {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .project-timeline-item {
    position: relative;
    padding-left: 1.75rem;
    padding-bottom: 1.5rem;
  }

  .project-timeline-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.875rem;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 9999px;
    background: var(--color-slate-700);
    box-shadow: 0 0 0 3px var(--color-slate-950);
    z-index: 1;
  }

  .project-timeline-item::after {
    content: '';
    position: absolute;
    left: calc(0.25rem - 0.5px);
    top: 1.5rem;
    bottom: 0;
    width: 1px;
    background: var(--color-slate-700);
  }

  .project-timeline-item:last-child::after {
    display: none;
  }
</style>
