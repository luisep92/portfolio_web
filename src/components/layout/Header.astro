---
import Container from '../ui/Container.astro';
import LocaleToggle from './LocaleToggle.astro';
import { getLocaleFromUrl, localizedPath, t } from '../../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
// Astro emits trailing slashes on sub-routes; normalize so the active-match
// comparison below treats `/projects` and `/projects/` as the same path.
const currentPath = Astro.url.pathname.replace(/\/+$/, '') || '/';

const navItems = [
  { key: 'nav.home' as const, basePath: '/' },
  { key: 'nav.projects' as const, basePath: '/projects' },
  { key: 'nav.articles' as const, basePath: '/articles' },
  { key: 'nav.now' as const, basePath: '/now' },
  { key: 'nav.contact' as const, basePath: '/contact' },
];

function isActive(basePath: string): boolean {
  const localizedBase = localizedPath(basePath, locale);
  // Home is exact-match only — otherwise the startsWith check below would
  // light it up on every page (`/es/projects` startsWith `/es/`...).
  if (basePath === '/') {
    return currentPath === localizedBase;
  }
  return currentPath === localizedBase || currentPath.startsWith(localizedBase + '/');
}
---

<header class="border-b border-slate-900">
  <Container class="flex flex-col items-start gap-3 py-6 sm:flex-row sm:items-center sm:justify-between sm:gap-8">
    <a
      href={localizedPath('/', locale)}
      class="text-sm font-medium text-slate-200 hover:text-slate-100 transition-colors"
    >
      {t(locale, 'site.title')}
    </a>
    <nav class="flex flex-wrap items-center gap-x-5 gap-y-2 sm:gap-6">
      {navItems.map((item) => (
        <a
          href={localizedPath(item.basePath, locale)}
          class:list={[
            'text-sm transition-colors',
            isActive(item.basePath)
              ? 'text-slate-100'
              : 'text-slate-400 hover:text-slate-100',
          ]}
        >
          {t(locale, item.key)}
        </a>
      ))}
      <LocaleToggle />
    </nav>
  </Container>
</header>
