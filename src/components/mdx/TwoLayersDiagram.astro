---
/**
 * Two-layer architecture for the "Three ways to test C++ from Python" article.
 * Python binds Layer A (pure logic) directly; Layer B (the I/O shell) wraps and
 * drives Layer A over sockets. Single-accent slate; the labels carry the meaning.
 */
---

<figure
  class="my-10 overflow-x-auto rounded border border-slate-800 bg-slate-900/40 px-4 py-6"
>
  <svg
    viewBox="0 0 760 250"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    aria-label="Python binds Layer A, the pure logic, directly. Layer B, the I/O shell of sockets and threads, wraps and drives Layer A."
    class="block w-full min-w-[600px]"
  >
    <!-- Python -->
    <rect x="30" y="95" width="150" height="70" rx="8" fill="#0f172a" stroke="#334155" stroke-width="1.25" />
    <text x="105" y="124" text-anchor="middle" font-family="system-ui, sans-serif" font-size="13" font-weight="600" fill="#e2e8f0">Python</text>
    <text x="105" y="142" text-anchor="middle" font-family="system-ui, sans-serif" font-size="10" fill="#94a3b8">tests · mock</text>
    <text x="105" y="156" text-anchor="middle" font-family="system-ui, sans-serif" font-size="10" fill="#94a3b8">orchestrator</text>

    <!-- Layer B outer -->
    <rect x="255" y="55" width="475" height="150" rx="10" fill="#0f172a" stroke="#334155" stroke-width="1.25" />
    <text x="492" y="78" text-anchor="middle" font-family="system-ui, sans-serif" font-size="12" font-weight="600" fill="#cbd5e1">Layer B — I/O shell</text>
    <text x="492" y="95" text-anchor="middle" font-family="system-ui, sans-serif" font-size="10" fill="#94a3b8">sockets · threads · server · client</text>

    <!-- Layer A inner -->
    <rect x="285" y="110" width="415" height="78" rx="8" fill="#0b1120" stroke="#64748b" stroke-width="1.5" />
    <text x="492" y="138" text-anchor="middle" font-family="system-ui, sans-serif" font-size="13" font-weight="700" fill="#e2e8f0">Layer A — pure logic</text>
    <text x="492" y="157" text-anchor="middle" font-family="system-ui, sans-serif" font-size="11" fill="#cbd5e1">protocol · room · session</text>
    <text x="492" y="174" text-anchor="middle" font-family="system-ui, sans-serif" font-size="10" fill="#64748b">no sockets · no threads</text>

    <!-- bind arrow (drawn last, on top) -->
    <line x1="182" y1="149" x2="281" y2="149" stroke="#475569" stroke-width="1.25" stroke-dasharray="4 3" marker-end="url(#tl-arrow)" />
    <text x="233" y="142" text-anchor="middle" font-family="ui-monospace, SFMono-Regular, Menlo, monospace" font-size="9" fill="#94a3b8">binds (Mode 1)</text>

    <!-- caption -->
    <text x="380" y="232" text-anchor="middle" font-family="ui-monospace, SFMono-Regular, Menlo, monospace" font-size="10" letter-spacing="1" fill="#64748b">THE PURE LAYER IS THE SEAM — BIND IT, DRIVE THE SHELL OVER A SOCKET</text>

    <defs>
      <marker id="tl-arrow" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto">
        <path d="M0,0 L8,3 L0,6 z" fill="#475569" />
      </marker>
    </defs>
  </svg>
</figure>
