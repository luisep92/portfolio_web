---
/**
 * Mode 3 (hybrid) topology for the "Three ways to test C++ from Python"
 * article: real C++ client devices and a Python mock, all on the real wire to
 * the real server; the orchestrator drives the devices and records via their
 * callbacks into a report. Single-accent slate.
 */
---

<figure
  class="my-10 overflow-x-auto rounded border border-slate-800 bg-slate-900/40 px-4 py-6"
>
  <svg
    viewBox="0 0 760 330"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    aria-label="Mode 3 topology: two real C++ client devices and a Python mock connect over the real wire to the real C++ server; the Python orchestrator drives the devices and records their callbacks into a report."
    class="block w-full min-w-[620px]"
  >
    <!-- Orchestrator -->
    <rect x="295" y="24" width="190" height="50" rx="8" fill="#0f172a" stroke="#334155" stroke-width="1.25" />
    <text x="390" y="46" text-anchor="middle" font-family="system-ui, sans-serif" font-size="12" font-weight="600" fill="#e2e8f0">Orchestrator (Python)</text>
    <text x="390" y="62" text-anchor="middle" font-family="system-ui, sans-serif" font-size="9.5" fill="#94a3b8">drives · records · reports</text>

    <!-- Report -->
    <rect x="545" y="30" width="180" height="40" rx="6" fill="#0b1120" stroke="#334155" stroke-width="1" stroke-dasharray="4 3" />
    <text x="635" y="54" text-anchor="middle" font-family="system-ui, sans-serif" font-size="10" fill="#cbd5e1">report · delivery matrix</text>
    <line x1="485" y1="49" x2="543" y2="49" stroke="#475569" stroke-width="1.25" marker-end="url(#hf-arrow)" />

    <!-- Server -->
    <rect x="315" y="180" width="150" height="66" rx="8" fill="#0b1120" stroke="#64748b" stroke-width="1.5" />
    <text x="390" y="210" text-anchor="middle" font-family="system-ui, sans-serif" font-size="13" font-weight="700" fill="#e2e8f0">C++ server</text>
    <text x="390" y="228" text-anchor="middle" font-family="system-ui, sans-serif" font-size="10" fill="#94a3b8">(real)</text>

    <!-- Client A -->
    <rect x="40" y="150" width="160" height="56" rx="8" fill="#0f172a" stroke="#334155" stroke-width="1.25" />
    <text x="120" y="174" text-anchor="middle" font-family="system-ui, sans-serif" font-size="11.5" font-weight="600" fill="#e2e8f0">C++ client</text>
    <text x="120" y="190" text-anchor="middle" font-family="system-ui, sans-serif" font-size="9.5" fill="#94a3b8">real bound device</text>

    <!-- Client B -->
    <rect x="40" y="232" width="160" height="56" rx="8" fill="#0f172a" stroke="#334155" stroke-width="1.25" />
    <text x="120" y="256" text-anchor="middle" font-family="system-ui, sans-serif" font-size="11.5" font-weight="600" fill="#e2e8f0">C++ client</text>
    <text x="120" y="272" text-anchor="middle" font-family="system-ui, sans-serif" font-size="9.5" fill="#94a3b8">real bound device</text>

    <!-- Mock -->
    <rect x="560" y="186" width="160" height="56" rx="8" fill="#0f172a" stroke="#334155" stroke-width="1.25" />
    <text x="640" y="210" text-anchor="middle" font-family="system-ui, sans-serif" font-size="11.5" font-weight="600" fill="#e2e8f0">Python mock</text>
    <text x="640" y="226" text-anchor="middle" font-family="system-ui, sans-serif" font-size="9.5" fill="#94a3b8">injector / observer</text>

    <!-- wire arrows (the real wire) -->
    <line x1="200" y1="180" x2="313" y2="203" stroke="#475569" stroke-width="1.5" marker-end="url(#hf-arrow)" />
    <line x1="200" y1="258" x2="313" y2="223" stroke="#475569" stroke-width="1.5" marker-end="url(#hf-arrow)" />
    <line x1="558" y1="214" x2="467" y2="214" stroke="#475569" stroke-width="1.5" marker-end="url(#hf-arrow)" />
    <text x="250" y="214" text-anchor="middle" font-family="ui-monospace, SFMono-Regular, Menlo, monospace" font-size="9" fill="#64748b">TCP · NDJSON</text>

    <!-- orchestrator drives + observes the devices (dashed) -->
    <line x1="300" y1="56" x2="202" y2="162" stroke="#475569" stroke-width="1.1" stroke-dasharray="4 3" />
    <line x1="300" y1="66" x2="202" y2="246" stroke="#475569" stroke-width="1.1" stroke-dasharray="4 3" />
    <text x="232" y="118" text-anchor="middle" font-family="system-ui, sans-serif" font-size="9" fill="#94a3b8">drives · on_message</text>

    <!-- caption -->
    <text x="380" y="312" text-anchor="middle" font-family="ui-monospace, SFMono-Regular, Menlo, monospace" font-size="10" letter-spacing="1" fill="#64748b">REAL CLIENTS + A PYTHON MOCK ON THE REAL WIRE — OBSERVED VIA CALLBACKS, NOT STDOUT</text>

    <defs>
      <marker id="hf-arrow" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto">
        <path d="M0,0 L8,3 L0,6 z" fill="#475569" />
      </marker>
    </defs>
  </svg>
</figure>
